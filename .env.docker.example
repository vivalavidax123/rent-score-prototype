# Copy to .env.docker, fill in the values, then run:
#   docker compose --env-file .env.docker up --build

# --- Required ---

# Google Maps Platform key (Geocoding, Places). Server-side only.
GOOGLE_MAPS_API_KEY=

# Session-cookie signing secret; any long random string works, e.g.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# --- Optional ---

# Same Maps key (or a browser-restricted one) for the embedded live map.
# Baked into the frontend at image build time — rebuild after changing it.
NEXT_PUBLIC_MAPS_API_KEY=

# Transit scores; without it the transit category is skipped.
TRANSITLAND_API_KEY=

# Google OAuth sign-in; leave empty to use email/password only. The OAuth
# redirect URI must include http://localhost:3000/api/auth/callback/google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only change if the app is served from a different origin.
BETTER_AUTH_URL=http://localhost:3000
